# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Google OAuth — sign-in only (scopes: openid email profile)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI per environment:
#   prod:    https://<your-prod-host>/api/auth/callback/google
#   preview: https://<your-preview-host>/api/auth/callback/google
#   local:   http://localhost:3000/api/auth/callback/google
GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# Reddit OAuth (separate connected account, NOT auth provider)
REDDIT_CLIENT_ID=your-reddit-app-id
REDDIT_CLIENT_SECRET=your-reddit-app-secret
REDDIT_REDIRECT_URI=http://localhost:3000/api/reddit/callback

# X OAuth (Free tier, for posting) - optional
X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret
X_REDIRECT_URI=http://localhost:3000/api/x/callback

# xAI (Grok search for X/Twitter) - optional
XAI_API_KEY=xai-xxx

# Encryption (AES-256-GCM for OAuth tokens)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug

# ---- Alpha gate / waitlist ----

# Random 32-byte hex used to salt SHA-256 of waitlist submitter IPs.
# Generate once per environment:
#   openssl rand -hex 32
# When unset, IP hashing is disabled (waitlist rows store null ipHash).
IP_HASH_SALT=

# ---- Email (Resend) ----

# Resend API key. When unset, sendEmail() is a graceful no-op (logs warn).
# Required in prod for admin notifications + approval emails.
RESEND_API_KEY=

# Verified Resend sender. Required when RESEND_API_KEY is set.
# Once you verify a domain (e.g. shipflare.ai) in Resend, ANY local-part
# on that domain works — alpha@, hello@, noreply@, etc. Prefer a display
# name so inboxes show "ShipFlare" instead of the raw address.
# Example: EMAIL_FROM="ShipFlare <alpha@shipflare.ai>"
EMAIL_FROM=
