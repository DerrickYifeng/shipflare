# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Postgres connection pool size in production. Default is 30, sized for
# the BullMQ workers (agent-run concurrency 8 + the other queues summing
# to ~24) plus connection headroom for cron + HTTP routes. Bump when
# adding workers or per-tenant concurrency caps. Must not exceed the
# Supabase project's pooler max_clients (Pro: 400, Free: 60). Leave
# unset in dev — the pool is hardcoded to 1 outside NODE_ENV=production.
PG_POOL_MAX=30

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6379

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
GITHUB_ID=your-github-oauth-app-id
GITHUB_SECRET=your-github-oauth-app-secret

# Google OAuth — sign-in only (scopes: openid email profile)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI per environment:
#   prod:    https://<your-prod-host>/api/auth/callback/google
#   preview: https://<your-preview-host>/api/auth/callback/google
#   local:   http://localhost:3000/api/auth/callback/google
GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# Reddit OAuth (separate connected account, NOT auth provider)
REDDIT_CLIENT_ID=your-reddit-app-id
REDDIT_CLIENT_SECRET=your-reddit-app-secret
REDDIT_REDIRECT_URI=http://localhost:3000/api/reddit/callback

# X OAuth (Free tier, for posting) - optional
X_CLIENT_ID=your-x-oauth-client-id
X_CLIENT_SECRET=your-x-oauth-client-secret
X_REDIRECT_URI=http://localhost:3000/api/x/callback

# xAI (Grok search for X/Twitter) - optional
XAI_API_KEY=xai-xxx

# Encryption (AES-256-GCM for OAuth tokens)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# Anthropic rate limits (B5 client-side bucket; see src/lib/redis-scripts/llm-token-bucket.ts)
# Per-tenant requests/minute. Default 60 sized for ~15 active tenants
# (60 × 15 = 900 = LLM_GLOBAL_RPM) at Tier 2.
LLM_TENANT_RPM=60
# Global account-wide requests/minute. Should be ≤ Anthropic's published Tier RPM
# with headroom for retries. Anthropic tiers (https://docs.anthropic.com/en/api/rate-limits):
# Tier 1 = 50 RPM, Tier 2 = 1000 RPM, Tier 3 = 2000 RPM. Default 900 sits ~10%
# under Tier 2's ceiling.
LLM_GLOBAL_RPM=900

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=debug

# ---- Alpha gate / waitlist ----

# Random 32-byte hex used to salt SHA-256 of waitlist submitter IPs.
# Generate once per environment:
#   openssl rand -hex 32
# When unset, IP hashing is disabled (waitlist rows store null ipHash).
IP_HASH_SALT=

# ---- Email (Resend) ----

# Resend API key. When unset, sendEmail() is a graceful no-op (logs warn).
# Required in prod for admin notifications + approval emails.
RESEND_API_KEY=

# Verified Resend sender. Required when RESEND_API_KEY is set.
# Once you verify a domain (e.g. shipflare.ai) in Resend, ANY local-part
# on that domain works — alpha@, hello@, noreply@, etc. Prefer a display
# name so inboxes show "ShipFlare" instead of the raw address.
# Example: EMAIL_FROM="ShipFlare <alpha@shipflare.ai>"
EMAIL_FROM=

# ---- Phase D durable-lead state machine (D3+) ----
#
# When true (default), processAgentRun runs a single leadStep per wake and
# yields the BullMQ slot between teammate spawns / sleeps / turns. When
# false (rollback), falls back to the legacy polling-drain runAgentTurn
# (preserved verbatim behind this flag for one release).
#
# Production deploy procedure (see D6 runbook):
#   1. Backfill in-flight runs: `pnpm tsx scripts/backfill-agent-runs-checkpoint.ts --commit`
#   2. Flip this flag to true.
#   3. Restart workers.
#
# Default is true in local dev / staging. Set to false for a one-flag rollback.
ENABLE_DURABLE_LEAD=true
