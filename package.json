{
  "name": "shipflare-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n next,redis,worker -c blue,red,magenta \"next dev\" \"redis-server --save '' --appendonly no\" \"bun --watch src/workers/index.ts\"",
    "dev:next": "next dev",
    "dev:worker": "bun --watch src/workers/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:visual": "playwright test e2e/tests/onboarding.spec.ts",
    "test:e2e:visual:update": "playwright test e2e/tests/onboarding.spec.ts --update-snapshots",
    "db:push": "drizzle-kit push",
    "db:migrate": "bun run scripts/run-migrations.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "seed-user": "bun run scripts/seed-user.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/turndown": "^5.0.6",
    "bullmq": "^5.73.4",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "fast-glob": "^3.3.3",
    "ioredis": "^5.10.1",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "picocolors": "^1.1.1",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1",
    "turndown": "^7.2.4",
    "twitter-text": "^3.1.0",
    "zod": "3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "happy-dom": "^20.9.0",
    "msw": "^2.13.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
