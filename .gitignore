# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/playwright-report/
/test-results/

# gstack
.gstack/
.gstack-audit/

# user uploads
/public/uploads/

# claude code
.claude/

# locally-installed agent skills (managed by skills-lock.json; kept out
# of the repo so each contributor can install or upgrade independently)
.agents/
skills-lock.json

# Remotion source for marketing hero video — the rendered .mp4 lives in
