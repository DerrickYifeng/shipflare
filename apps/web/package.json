{
  "name": "@shipflare/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "pnpm run build:worker && wrangler dev",
    "deploy": "pnpm run build:worker && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@cloudflare/ai-chat": "^0.7.0",
    "@opennextjs/cloudflare": "^1.19.9",
    "@shipflare/crypto": "workspace:*",
    "@shipflare/db": "workspace:*",
    "@shipflare/shared": "workspace:*",
    "agents": "^0.12.4",
    "ai": "^6.0.184",
    "better-auth": "^1.6.11",
    "eventsource-parser": "^3.0.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
