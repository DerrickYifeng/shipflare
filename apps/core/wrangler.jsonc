{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "shipflare-core",
	"main": "src/index.ts",
	"compatibility_date": "2026-05-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	},
	// D1 binding for cross-team data (user / session / account / verification / channels).
	//
	// `database_id` is a PLACEHOLDER. wrangler / vitest-pool-workers only require
	// `binding` + `database_name` for local (miniflare-backed) operation. Before
	// a real `wrangler deploy` (production), run:
	//   wrangler d1 create shipflare-prod
	// and paste the returned UUID here.
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "shipflare-prod",
			"database_id": "a34a9f67-0c80-4788-b9bb-ee37728b40fb",
			"migrations_dir": "../../packages/db/migrations"
		}
	],
	// Durable Object bindings — class declarations come in S2-S5.
	//
	// Bindings are listed in this comment so wrangler.jsonc remains the single
	// source of truth for binding-name → class-name mapping. The names below
	// MUST match `packages/shared/src/role-registry.ts` ROLE_REGISTRY[*].binding
	// and the wrangler bindings literal type expected by the DO API. Anything
	// we name here is what the runtime hands the parent agent when it calls
	// `addMcpServer(name, env[binding], ...)`.
	//
	// Phase 0 spike #2 finding (see RESULTS.md): every `addMcpServer` call
	// MUST use a per-tenant unique `name` (e.g. `${role}-${userId}`) otherwise
	// the McpServer DO is shared across tenants. The binding name is the env
	// key — `name` is the DO id input. See `packages/shared/mcpServerName`.
	"durable_objects": {
		"bindings": [
			// S2 — CMO
			{
				"name": "CMO",
				"class_name": "CMO"
			},
			// S3 — Head of Growth (renamed v11 from HeadOfGrowth → HoG)
			{
				"name": "HOG",
				"class_name": "HoG"
			},
			// S4 — Social Media Manager (renamed v10 from SocialMediaMgr → SMM)
			{
				"name": "SMM",
				"class_name": "SMM"
			},
			// S5 — Platform tool MCPs (landed S5.3 under migration tag v4)
			{
				"name": "X_MCP",
				"class_name": "XMcpAgent"
			},
			{
				"name": "REDDIT_MCP",
				"class_name": "RedditMcpAgent"
			},
			// S7 — External MCP surface (Phase 7). Per-user DO that holds the
			// OAuth-scoped, chat-only tool surface exposed at
			// mcp.shipflare.com/cmo. Backed by SQLite via migration v13.
			{
				"name": "CMO_EXTERNAL_MCP",
				"class_name": "CmoExternalMcp"
			}
		]
	},
	// KV namespace for `@cloudflare/workers-oauth-provider` (Phase 7). Stores
	// OAuth 2.1 client registrations, authorization codes, and refresh tokens
	// for the external MCP surface. Created via
	// `wrangler kv namespace create OAUTH_KV` (prod + --preview).
	"kv_namespaces": [
		{
			"binding": "OAUTH_KV",
			"id": "7d866a4ae83847e080410ede3fcb7c24",
			"preview_id": "073815de9829474bb08d938a26d16f7b"
		}
	],
	// Phase 7.5 — Service Binding back to `shipflare-web`. Used by
	// `external/auth-handler.ts` to delegate Better-Auth session-cookie
	// verification on `/authorize` POST. apps/web already binds to core
	// (CORE binding) — this is the reverse direction. Phase 0 spike #8
	// finding: Service Bindings strip `host` + `cf-connecting-ip`; the
	// auth handler forwards only `cookie`, so that's not an issue here.
	//
	// Mutual deploy ordering: both Workers must exist for the binding to
	// resolve at runtime. Deploy apps/web first, then apps/core (or vice
	// versa with `wrangler deploy --keep-vars` so the binding is allowed
	// to be unresolved on the first deploy).
	"services": [
		{ "binding": "WEB", "service": "shipflare-web" }
	],
	// Wrangler migration tags are append-only. Adding a class to an existing tag
	// after it's already been applied to a running env won't take effect — new
	// SQLite-backed DO classes must use a NEW tag (v2, v3, ...). Never modify
	// a tag once applied.
	//
	// Per Phase 0 spike #2 finding: omit `new_sqlite_classes` here entirely (vs.
	// an empty array) — the spike validated that an empty migrations array is
	// accepted by wrangler at startup. Each tag below comes online with its
	// DO class in the matching S-task.
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"CMO"
			]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": [
				"HeadOfGrowth"
			]
		},
		{
			"tag": "v3",
			"new_sqlite_classes": [
				"SocialMediaMgr"
			]
		},
		{
			"tag": "v4",
			"new_sqlite_classes": [
				"XMcpAgent",
				"RedditMcpAgent"
			]
		},
		// P2-B and P2-E expanded the roster + platform surface beyond what the
		// design doc called for (3 employees + 2 platform MCPs). v5-v8 created
		// Copywriter / BrandAnalyst / CommunityManager / LinkedIn / HN / Discord
		// — v9 retires all six. Wrangler migration tags are append-only; the
		// previous tags MUST stay in the array even though the classes are gone,
		// otherwise wrangler refuses to deploy ("missing applied migration").
		{
			"tag": "v5",
			"new_sqlite_classes": [
				"Copywriter"
			]
		},
		{
			"tag": "v6",
			"new_sqlite_classes": [
				"BrandAnalyst"
			]
		},
		{
			"tag": "v7",
			"new_sqlite_classes": [
				"CommunityManager"
			]
		},
		{
			"tag": "v8",
			"new_sqlite_classes": [
				"LinkedInMcpAgent",
				"HackerNewsMcpAgent",
				"DiscordMcpAgent"
			]
		},
		{
			"tag": "v9",
			"deleted_classes": [
				"Copywriter",
				"BrandAnalyst",
				"CommunityManager",
				"LinkedInMcpAgent",
				"HackerNewsMcpAgent",
				"DiscordMcpAgent"
			]
		},
		// v10 — CF-native chat migration Task 4.4c. The SMM class was rewritten
		// from McpAgent to AIChatAgent in the same file; the class export name
		// changed from `SocialMediaMgr` to `SMM`. We are still in dev stage,
		// so the old per-DO SQLite (threads_inbox / drafts / voice_audit) is
		// not worth preserving — delete the old class namespace cleanly and
		// stand up `SMM` as a fresh SQLite-backed DO. AIChatAgent bootstraps
		// its own chat-history schema on first message.
		{
			"tag": "v10",
			"deleted_classes": ["SocialMediaMgr"],
			"new_sqlite_classes": ["SMM"]
		},
		// v11 — CF-native chat migration Task 4.5b. Same shape as v10 for HoG:
		// HeadOfGrowth → HoG with a clean DO namespace (planning_chat /
		// proposal_drafts / audit_findings dropped — dev-stage, not worth
		// preserving). AIChatAgent bootstraps chat-history tables on first
		// message.
		{
			"tag": "v11",
			"deleted_classes": ["HeadOfGrowth"],
			"new_sqlite_classes": ["HoG"]
		},
		// v12 — Phase 7 external MCP surface. CmoExternalMcp is a chat-only,
		// OAuth-scoped per-user McpAgent exposed at mcp.shipflare.com/cmo.
		// SQLite-backed so the OAuth provider can store client + token state
		// per tenant.
		//
		// NOTE (2026-05-18 Phase 11.2a): the original CF-native chat migration
		// proposed a v12 to delete+recreate the CMO class for a clean per-DO
		// SQLite namespace (drop the retired conversations / founder_messages /
		// roster / activity_events tables). CF rejects same-name delete+create
		// in one tag (code 10021) AND rejects splitting it without first
		// removing the binding (code 10061). The clean-reset would require a
		// two-deploy dance (remove binding → deploy → re-add → deploy).
		// Punt: applyCmoSchema uses `CREATE TABLE IF NOT EXISTS` so it
		// initializes the new tables alongside any stale legacy ones. The
		// retired tables are dead weight but harmless (no writer exists in the
		// new AIChatAgent CMO).
		{
			"tag": "v12",
			"new_sqlite_classes": ["CmoExternalMcp"]
		}
	],
	// Ops telemetry — single Analytics Engine dataset for agent / skill /
	// tool events. Replaces the bespoke `activity_events` D1 table written
	// from `apps/core/src/lib/activity.ts`. Phase 5 of the CF-native chat
	// migration plan deletes the legacy writer once consumers read this
	// dataset via the Cloudflare SQL API.
	"analytics_engine_datasets": [
		{
			"binding": "TELEMETRY",
			"dataset": "shipflare_agent_events"
		}
	],
	// Dynamic Workflow binding — class lands in a later task. AgentPlanWorkflow
	// drives long-running multi-step orchestration spawned by CMO when plans
	// exceed a single MCP call's lifetime (e.g. multi-platform inbound sweep).
	"workflows": [
		// { "binding": "AGENT_PLAN_WORKFLOW", "name": "agent-plan-workflow", "class_name": "AgentPlanWorkflow" }
	],
	// Cron trigger — Phase 1 fan-out to active CMOs hourly for inbound sweep.
	// The cron handler (`scheduled()` in src/index.ts) is wired in S2.6 / S6.
	// Hourly cadence; tighten in dev by overriding via `wrangler dev` flag if
	// you need to exercise the path more frequently.
	"triggers": {
		"crons": [
			"0 0/6 * * *"
		]
	},
	// Secrets are NOT declared in wrangler.jsonc (would leak the value into
	// the generated `Cloudflare.Env` as a literal type, breaking the wider
	// `string` constraint our `Env` interface declares).
	//
	// Instead, `.dev.vars` supplies test + `wrangler dev` defaults and
	// production runs `wrangler secret put MCP_JWT_SECRET` (and the same
	// for ANTHROPIC_API_KEY / XAI_API_KEY / CHANNEL_ENC_KEY).
	//
	// apps/web must hold the same MCP_JWT_SECRET — both sides verify the
	// HS256 signature with one shared secret.
	//
	// Test-only bindings — DO NOT add here. The following bindings exist
	// solely as security gates for test seams and are set ONLY in
	// `apps/core/vitest.config.mts` under `miniflare.bindings`. Adding any
	// of them to wrangler.jsonc activates the seam in production:
	//   - `STRATEGIC_PATH_FIXTURE` — gates the Anthropic short-circuit in
	//     `onboarding-routes.ts`. Leaking it lets any browser force the
	//     fixture path and skip LLM + schema validation.
	//   - `EXTERNAL_AUTH_TEST_SEAM` (Phase 7.3) — gates the
	//     `x-test-user-id` header read in `external/auth-handler.ts`.
	//     Leaking it lets any caller mint an OAuth code for any victim's
	//     userId (PKCE only proves same-client; it doesn't authenticate
	//     the user).

	// --- Environments ---
	//
	// Deploy to staging:   ./scripts/deploy-staging.sh
	//   or manually:       wrangler deploy --env staging
	//
	// Staging uses a separate D1 database (shipflare-staging) so schema
	// experiments can't corrupt production data. All other bindings
	// (DO classes, migrations, crons) are inherited from the top-level config.
	//
	// One-time staging setup:
	//   cd apps/core && pnpm exec wrangler d1 create shipflare-staging
	//   paste the returned database_id below AND in apps/web/wrangler.jsonc
	//   pnpm exec wrangler d1 migrations apply shipflare-staging --remote --env staging
	//   set secrets:  wrangler secret put ANTHROPIC_API_KEY --env staging  (etc.)
	"env": {
		"staging": {
			"name": "shipflare-core-staging",
			// Custom subdomain so the Better Auth session cookie (set with
			// `domain=.shipflare.ai` by apps/web staging) is included on
			// the `/authorize` request from a browser tab opened by an
			// external MCP client. *.workers.dev is on the Public Suffix
			// List, so cookies cannot be shared across subdomains there
			// — the cross-domain handshake only works on a real zone.
			"routes": [
				{ "pattern": "mcp-staging.shipflare.ai", "custom_domain": true }
			],
			"d1_databases": [
				{
					"binding": "DB",
					"database_name": "shipflare-staging",
					"database_id": "98184513-f82d-4d6e-83d5-cc415e8e950f",
					"migrations_dir": "../../packages/db/migrations"
				}
			],
			// durable_objects and workflows are not inherited by environments —
			// they must be repeated here verbatim.
			"durable_objects": {
				"bindings": [
					{ "name": "CMO", "class_name": "CMO" },
					{ "name": "HOG", "class_name": "HoG" },
					{ "name": "SMM", "class_name": "SMM" },
					{ "name": "X_MCP", "class_name": "XMcpAgent" },
					{ "name": "REDDIT_MCP", "class_name": "RedditMcpAgent" },
					{ "name": "CMO_EXTERNAL_MCP", "class_name": "CmoExternalMcp" }
				]
			},
			// kv_namespaces are not inherited by environments either. Staging
			// reuses the same OAuth_KV namespace as production for Phase 7 —
			// switch to a separate namespace if staging needs isolated OAuth
			// state. (Create with `wrangler kv namespace create OAUTH_KV_STAGING`
			// and paste the id here.)
			"kv_namespaces": [
				{
					"binding": "OAUTH_KV",
					"id": "7d866a4ae83847e080410ede3fcb7c24",
					"preview_id": "073815de9829474bb08d938a26d16f7b"
				}
			],
			// Staging reverse-direction service binding to apps/web staging.
			// Mirrors the top-level prod entry; required because environments
			// don't inherit service bindings from the top-level config.
			"services": [
				{ "binding": "WEB", "service": "shipflare-web-staging" }
			],
			"workflows": [],
			"analytics_engine_datasets": [
				{
					"binding": "TELEMETRY",
					"dataset": "shipflare_agent_events_staging"
				}
			]
		}
	}
}